# ---------------------------------------------------------------------------
# Database — Supabase (PostgreSQL)
# ---------------------------------------------------------------------------
# In Supabase: Project → Connect → ORMs (Prisma). Copy the two strings below.
#
# DATABASE_URL = the "Transaction" pooler string (host contains "pooler",
#   port 6543). It MUST include ?pgbouncer=true — this is what the app uses.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL = the "Session" pooler string (same host, port 5432). Used only by
#   `prisma migrate`.
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Authentication (Auth.js / NextAuth v5)
# ---------------------------------------------------------------------------
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-long-random-string"

# ---------------------------------------------------------------------------
# Payments (Stripe) — subscription: A$200 / month
# ---------------------------------------------------------------------------
# Stripe Dashboard → Developers → API keys → Secret key (starts with sk_test_).
STRIPE_SECRET_KEY="sk_test_xxx"
# Stripe → Products → create "Greenlight Pro" A$200/month → copy the Price ID (price_...).
STRIPE_PRICE_ID="price_xxx"
# The signing secret for your webhook endpoint (whsec_...). From the Stripe CLI
# locally, or Dashboard → Developers → Webhooks in production.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public base URL — used to build Stripe return links. Set to your Vercel URL in
# production (e.g. https://greenlight.vercel.app).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Greenlight"

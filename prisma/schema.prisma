// Greenlight — Prisma schema
// Multi-tenant residential development approval tracker for South Australia.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (used by the app at runtime — safe for serverless / scale).
  url       = env("DATABASE_URL")
  // Direct connection (used only by `prisma migrate`). Falls back to DATABASE_URL
  // if you don't set it.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  APPROVED
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkflowType {
  PLANNING
  DEVELOPMENT
  LAND_DIVISION
}

enum TaskStatus {
  NOT_STARTED
  REQUESTED
  IN_PROGRESS
  RECEIVED
  LODGED
  RFI_RECEIVED
  WAITING
  APPROVED
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ContactRole {
  ARCHITECT
  ENGINEER
  LAND_DIVISION_COMPANY
  SURVEYOR
  COUNCIL_CONTACT
  TAKE_OFF_COMPANY
  PRIVATE_CERTIFIER
  BUILDER
  CLIENT
  OTHER
}

enum RFIStatus {
  OPEN
  IN_PROGRESS
  RESPONDED
  SUBMITTED
  CLOSED
}

enum DocumentType {
  LAND_PAPERS
  CONTOUR_SURVEY
  BORE_LOG
  CONCEPT_PLAN
  PLANNING_DRAWINGS
  SD_PLAN
  PLANNING_APPROVAL
  WORKING_DRAWINGS
  ENERGY_RATING
  FOOTING_REPORT
  TAKE_OFF
  CITB_RECEIPT
  BRC_CERTIFICATE
  LD_DRAFT_PLAN
  LD_APPROVAL
  SA_WATER_INVOICE
  OPEN_SPACE_INVOICE
  SCAP_PLAN
  FINAL_TITLES
  OTHER
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  passwordHash         String?
  role                 UserRole @default(STAFF)
  image                String? // profile picture (data URL)
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // --- Billing (Stripe subscription) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeStatus           String? // active, trialing, past_due, canceled, ...
  stripeCurrentPeriodEnd DateTime?

  // Tenant data owned by this account.
  ownedProjects    Project[]             @relation("ProjectOwner")
  contacts         Contact[]
  durationSettings TaskDurationSetting[]
  councils         Council[]

  assignedProjects Project[]     @relation("ProjectAssignee")
  ownedRfis        RFI[]         @relation("RfiInternalOwner")
  activities       ActivityLog[]
}

model Project {
  id               String        @id @default(cuid())
  name             String
  address          String?
  clientName       String?
  clientPhone      String?
  clientEmail      String?
  lotNumber        String?
  council          String?
  applicationNumber String?
  planSAReference  String?
  status           ProjectStatus @default(ACTIVE)
  priority         Priority      @default(MEDIUM)
  startDate        DateTime?
  targetDate       DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("ProjectAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  workflows        Workflow[]
  tasks            Task[]
  rfis             RFI[]
  documents        Document[]
  notes_list       Note[]
  activities       ActivityLog[]
  projectContacts  ProjectContact[]

  @@index([ownerId])
  @@index([status])
  @@index([council])
}

model Contact {
  id            String      @id @default(cuid())
  companyName   String
  contactPerson String?
  role          ContactRole
  phone         String?
  email         String?
  address       String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  projectContacts ProjectContact[]
  tasks           Task[]
  rfis            RFI[]           @relation("RfiResponsibleContact")

  @@index([ownerId])
  @@index([role])
}

model ProjectContact {
  id        String      @id @default(cuid())
  projectId String
  contactId String
  role      ContactRole
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([projectId, contactId, role])
  @@index([projectId])
}

model Workflow {
  id        String       @id @default(cuid())
  projectId String
  type      WorkflowType
  title     String
  status    TaskStatus   @default(NOT_STARTED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, type])
  @@index([projectId])
}

model Task {
  id                String     @id @default(cuid())
  projectId         String
  workflowId        String
  title             String
  description       String?
  responsibleParty  String?
  contactId         String?
  status            TaskStatus @default(NOT_STARTED)
  priority          Priority   @default(MEDIUM)
  requestedDate     DateTime?
  dueDate           DateTime?
  completedDate     DateTime?
  estimatedDays     Int?
  dependencyTaskIds Json?
  customFields      Json?
  notes             String?
  sortOrder         Int        @default(0)
  isRepeatable      Boolean    @default(false)
  templateKey       String?
  parentTaskId      String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflow   Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  parentTask Task?      @relation("TaskVariations", fields: [parentTaskId], references: [id], onDelete: Cascade)
  variations Task[]     @relation("TaskVariations")
  documents  Document[]
  notes_list Note[]

  @@index([projectId])
  @@index([workflowId])
  @@index([status])
}

model RFI {
  id                   String       @id @default(cuid())
  projectId            String
  workflowType         WorkflowType
  rfiNumber            Int
  title                String
  description          String?
  receivedFrom         String?
  responsibleContactId String?
  internalOwnerId      String?
  dateReceived         DateTime?
  dueDate              DateTime?
  responseReceivedDate DateTime?
  submittedDate        DateTime?
  status               RFIStatus    @default(OPEN)
  notes                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responsibleContact Contact? @relation("RfiResponsibleContact", fields: [responsibleContactId], references: [id], onDelete: SetNull)
  internalOwner      User?    @relation("RfiInternalOwner", fields: [internalOwnerId], references: [id], onDelete: SetNull)
  notes_list         Note[]

  @@unique([projectId, workflowType, rfiNumber])
  @@index([projectId])
  @@index([status])
}

model Document {
  id           String       @id @default(cuid())
  projectId    String
  workflowType WorkflowType?
  taskId       String?
  documentType DocumentType
  name         String
  version      Int          @default(1)
  fileUrl      String?
  uploadedBy   String?
  uploadedDate DateTime     @default(now())
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model Note {
  id        String   @id @default(cuid())
  projectId String
  taskId    String?
  rfiId     String?
  content   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  rfi     RFI?    @relation(fields: [rfiId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  taskId    String?
  rfiId     String?
  action    String
  oldValue  String?
  newValue  String?
  createdBy String?
  userId    String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Settings — editable councils, roles and default durations (admin config)
// ---------------------------------------------------------------------------

model Council {
  id        String   @id @default(cuid())
  name      String
  region    String?
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, name])
  @@index([ownerId])
}

model TaskDurationSetting {
  id            String       @id @default(cuid())
  templateKey   String
  workflowType  WorkflowType
  label         String
  estimatedDays Int
  updatedAt     DateTime     @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, templateKey])
  @@index([ownerId])
}
